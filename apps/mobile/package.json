{
  "name": "recipeassistantapp",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:dev": "cp .env.development .env && npx expo start --clear --reset-cache",
    "start:prod": "cp .env.production .env && npx expo start --clear --reset-cache",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "@expo-google-fonts/playfair-display": "^0.4.2",
    "axios": "^1.18.0",
    "expo": "~54.0.36",
    "expo-constants": "~18.0.13",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-safe-area-context": "~5.6.0"
  }, 
  "private": true
}
